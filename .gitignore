# Dependencies
node_modules/

# Next.js build output
.next/
out/
tsconfig.tsbuildinfo

# Environment variables — never commit these
.env.local
.env*.local

# Vercel
.vercel

# Claude — track shared agents/commands, ignore per-user local settings
.claude/settings.local.json

# OS
.DS_Store

# ─── Terraform ─────────────────────────────────────────────
# Downloaded providers and modules
**/.terraform/*

# State files — can contain secrets, never commit
*.tfstate
*.tfstate.*

# Variable files often hold secrets
*.tfvars
*.tfvars.json

# Plan output files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Local CLI config
.terraformrc
terraform.rc
