{
  "name": "lionade",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:migrations": "bash scripts/check-migration-rls.sh",
    "seed:questions": "npx tsx scripts/seed-questions.ts",
    "core:typecheck": "npm --workspace @lionade/core run typecheck",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/supabase-js": "^2.97.0",
    "@types/leaflet": "^1.9.12",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "next": "^14.2.35",
    "pdf-parse": "^2.4.5",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1",
    "resend": "^6.9.2",
    "stripe": "^20.4.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
