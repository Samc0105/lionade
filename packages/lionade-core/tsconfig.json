{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    // "DOM" is included so we get types for the Web Platform standards
    // (fetch, Response, Headers, RequestInit). These are runtime-available
    // in Node 18+, modern browsers, and React Native. Other DOM globals
    // (window, document, localStorage) are still banned via ESLint
    // (.eslintrc.cjs → no-restricted-globals).
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "types": []
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
