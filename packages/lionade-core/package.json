{
  "name": "@lionade/core",
  "version": "0.0.0",
  "private": true,
  "description": "Shared business logic, types, API client, and constants for Lionade web and iOS apps. Platform-agnostic — no React, RN, Next, Expo, DOM, or node:* imports.",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "react-native": "./src/types/index.ts",
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./types/supabase": {
      "react-native": "./src/types/supabase.ts",
      "types": "./src/types/supabase.ts",
      "default": "./src/types/supabase.ts"
    },
    "./logic": {
      "react-native": "./src/logic/index.ts",
      "types": "./src/logic/index.ts",
      "default": "./src/logic/index.ts"
    },
    "./logic/*": {
      "react-native": "./src/logic/*.ts",
      "types": "./src/logic/*.ts",
      "default": "./src/logic/*.ts"
    },
    "./constants": {
      "react-native": "./src/constants/index.ts",
      "types": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    },
    "./constants/*": {
      "react-native": "./src/constants/*.ts",
      "types": "./src/constants/*.ts",
      "default": "./src/constants/*.ts"
    },
    "./api": {
      "react-native": "./src/api/index.ts",
      "types": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    },
    "./api/*": {
      "react-native": "./src/api/*.ts",
      "types": "./src/api/*.ts",
      "default": "./src/api/*.ts"
    },
    "./prompts/*": {
      "react-native": "./src/prompts/*.ts",
      "types": "./src/prompts/*.ts",
      "default": "./src/prompts/*.ts"
    },
    "./validation": {
      "react-native": "./src/validation/index.ts",
      "types": "./src/validation/index.ts",
      "default": "./src/validation/index.ts"
    },
    "./validation/*": {
      "react-native": "./src/validation/*.ts",
      "types": "./src/validation/*.ts",
      "default": "./src/validation/*.ts"
    },
    "./hooks/*": {
      "react-native": "./src/hooks/*.ts",
      "types": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  }
}
