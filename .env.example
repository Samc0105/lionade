# Lionade - environment variable template.
#
# Copy to .env.local for local dev and fill in real values. NEVER commit real
# secrets - .env.local and .env*.local are gitignored; this .example file is the
# only env file that is checked in, and it must contain placeholders only.
#
# On Vercel, set these under Project Settings → Environment Variables. Note which
# environments (Production / Preview / Development) each value applies to.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server-only, bypasses RLS - never expose to the client).
SUPABASE_SECRET_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Default From address, e.g. "Lionade <hello@getlionade.com>".
EMAIL_FROM=

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ── AI providers ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# ── Site / CDN ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_CDN_URL=

# ── Cloudflare Email Routing (admin team management) ──────────────────────────
# Used by the internal Admin → Team screen to create/destroy @getlionade.com
# routing addresses for team members. Read at call time only - a missing value
# returns a clear "not configured: set X" error, it does NOT crash on boot.
#
# Token scope: create a scoped API token with exactly
#   Zone → Email Routing → Edit
# on the getlionade.com zone (do not use a Global API Key).
CLOUDFLARE_API_TOKEN=
# The getlionade.com zone ID (Cloudflare dashboard → getlionade.com → Overview,
# right-hand "API" panel → Zone ID).
CLOUDFLARE_ZONE_ID=
# The email-routing domain. Should match the zone above.
CLOUDFLARE_EMAIL_ROUTING_DOMAIN=getlionade.com

# NOTE on Resend: RESEND_API_KEY already exists above and is reused by the team
# onboarding flow (welcome email + send-as SMTP via smtp.resend.com). No new key
# is needed for Resend. The Cloudflare token above MUST be added to BOTH the
# Vercel Production AND Preview environments so admin team management works in
# preview deploys as well as production.
