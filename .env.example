# Lionade - environment variable template.
#
# Copy to .env.local for local dev and fill in real values. NEVER commit real
# secrets - .env.local and .env*.local are gitignored; this .example file is the
# only env file that is checked in, and it must contain placeholders only.
#
# On Vercel, set these under Project Settings → Environment Variables. Note which
# environments (Production / Preview / Development) each value applies to.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server-only, bypasses RLS - never expose to the client).
SUPABASE_SECRET_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Default From address, e.g. "Lionade <hello@getlionade.com>".
EMAIL_FROM=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Keys (use sk_live_ / pk_live_ / live whsec_ on production; test_ locally).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs — REQUIRED for checkout. Each maps a plan/pack to a Stripe price_...
# created in the Dashboard (SAME mode as the secret key). Until each is set, that
# product's checkout 500s ("Plan unavailable" / "Pack unavailable"). Subscriptions
# are recurring prices; Fang packs are one-time prices.
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_PLATINUM_MONTHLY=
STRIPE_PRICE_ID_PLATINUM_ANNUAL=
STRIPE_PRICE_ID_FANGS_S=
STRIPE_PRICE_ID_FANGS_M=
STRIPE_PRICE_ID_FANGS_L=
STRIPE_PRICE_ID_FANGS_XL=
# Optional: only set =true AFTER Stripe Tax is configured, else session-create fails.
# STRIPE_AUTOMATIC_TAX=false

# ── AI providers ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# ── Site / CDN ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_CDN_URL=

# ── Cloudflare Email Routing (admin team management) ──────────────────────────
# Used by the internal Admin → Team screen to create/destroy @getlionade.com
# routing addresses for team members. Read at call time only - a missing value
# returns a clear "not configured: set X" error, it does NOT crash on boot.
#
# Token scope: create a scoped API token with exactly
#   Zone → Email Routing → Edit
# on the getlionade.com zone (do not use a Global API Key).
CLOUDFLARE_API_TOKEN=
# The getlionade.com zone ID (Cloudflare dashboard → getlionade.com → Overview,
# right-hand "API" panel → Zone ID).
CLOUDFLARE_ZONE_ID=
# The email-routing domain. Should match the zone above.
CLOUDFLARE_EMAIL_ROUTING_DOMAIN=getlionade.com

# NOTE on Resend: RESEND_API_KEY already exists above and is reused by the team
# onboarding flow (welcome email + send-as SMTP via smtp.resend.com). No new key
# is needed for Resend. The Cloudflare token above MUST be added to BOTH the
# Vercel Production AND Preview environments so admin team management works in
# preview deploys as well as production.

# ── Security monitoring (internal telemetry) ──────────────────────────────────
# Shared secret that authenticates middleware (Edge runtime) when it posts
# security events to the internal node routes (/api/internal/*). The same value
# is read server-side by middleware and by those routes to verify the caller.
# This is a server-side edge secret, NOT a NEXT_PUBLIC value - never expose it to
# the client. Generate a long random value with:
#   openssl rand -base64 32
INTERNAL_TELEMETRY_SECRET=

# ── Cron authentication ───────────────────────────────────────────────────────
# Bearer token Vercel sends in the Authorization header when invoking cron
# endpoints (vercel.json → crons). If unset, ALL cron routes return 500.
# Generate: openssl rand -base64 32
CRON_SECRET=

# ── Credential encryption (server-side, at-rest) ──────────────────────────────
# Symmetric key used to encrypt/decrypt stored credentials at rest. Server-side
# only - this is NOT a NEXT_PUBLIC value, never expose it to the client.
# Generate a long random value with:
#   openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=
# OPTIONAL. Only set this during a key rotation. While rotating, point this at
# the OLD key and let CREDENTIAL_ENCRYPTION_KEY hold the NEW key, so existing
# ciphertext can still be decrypted while new writes use the new key. Once the
# rotation completes (all stored credentials re-encrypted under the new key),
# this variable can be removed. Generate it the same way as the active key:
#   openssl rand -base64 32
# Like the active key, this is server-side only and must never be NEXT_PUBLIC.
CREDENTIAL_ENCRYPTION_KEY_PREVIOUS=
