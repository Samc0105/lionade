{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "functions": {
    "app/api/ninny/generate/route.ts": {
      "maxDuration": 60
    },
    "app/api/ninny/chat/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/reap-afk-presence",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/academia-digest",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/reap-stale-competitive",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/reap-pending-deletions",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/expire-grants",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/team-mfa-enforce",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/security-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/feature-health",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/curate-question-bank",
      "schedule": "0 10 * * *"
    }
  ]
}
